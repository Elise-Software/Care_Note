# WSL local gateway settings. Do not place SSH private keys or API secrets here.
WAVELAB_ENABLE_AI=1
WAVELAB_AI_HOST=your-private-ai-host
WAVELAB_AI_SSH_PORT=22
WAVELAB_AI_USER=your-ssh-user
# Optional explicit key path. The default is ~/.ssh/id_ed25519.
# WAVELAB_SSH_KEY=
WAVELAB_TUNNEL_PORT=11435
